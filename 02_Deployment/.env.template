# ============================================================================
# AZURE COSMOS DB CONFIGURATION
# ============================================================================
AZURE_SUBSCRIPTION_ID="064f47f7-1d35-49b6-a25b-cea76808d203"
AZURE_RESOURCE_GROUP="fields-property-rg"
AZURE_REGION="australiaeast"
COSMOS_ACCOUNT_NAME="fields-property-cosmos"

# This will be populated by 02_get_connection_string.sh
# Format: mongodb://fields-property-cosmos:PRIMARY_KEY@fields-property-cosmos.mongo.cosmos.azure.com:10255/?ssl=true&replicaSet=globaldb&retrywrites=false&maxIdleTimeMS=120000&appName=@fields-property-cosmos@
COSMOS_CONNECTION_STRING=""

