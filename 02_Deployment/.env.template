# GOOGLE CLOUD VM CONFIGURATION
# ============================================================================
GCP_PROJECT_ID="fields-estate"
GCP_REGION="australia-southeast1"
GCP_ZONE="australia-southeast1-b"
GCP_VM_NAME="fields-orchestrator-vm"
GCP_MACHINE_TYPE="e2-medium"

# ============================================================================
# DATABASE NAMES (must match your existing MongoDB databases)
# ============================================================================
DB_PROPERTY_DATA="property_data"
DB_GOLD_COAST_FOR_SALE="Gold_Coast_Currently_For_Sale"
