map $http_upgrade $connection_upgrade {
    default upgrade;
    ""      close;
}

server {
    listen 80;
    server_name vm.fieldsestate.com.au;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl;
    server_name vm.fieldsestate.com.au;

    ssl_certificate /etc/letsencrypt/live/vm.fieldsestate.com.au/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/vm.fieldsestate.com.au/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;

    location / {
        proxy_pass https://127.0.0.1:7681;
        proxy_ssl_verify off;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $connection_upgrade;
        proxy_set_header Host $host;
        proxy_read_timeout 3600s;
        proxy_send_timeout 3600s;
        proxy_buffering off;
        proxy_cache off;
    }

    # Audio library (token-gated path)
    location /audio/ {
        alias /home/fields/audio_library/mp3/;
        autoindex off;
        add_header Cache-Control "public, max-age=86400";
        types {
            audio/mpeg mp3;
            application/rss+xml xml;
        }
    }

    location /code/ {
        proxy_pass http://127.0.0.1:8080/;
        proxy_set_header Host $host;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection upgrade;
        proxy_set_header Accept-Encoding gzip;
        proxy_http_version 1.1;
        proxy_read_timeout 3600s;
        proxy_send_timeout 3600s;
        proxy_buffering off;
    }

    # Email/appraisal tracking server (PDF viewer, pixel, status)
    location /track/ {
        proxy_pass http://127.0.0.1:3051/;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_http_version 1.1;
        proxy_read_timeout 120s;
    }
}
