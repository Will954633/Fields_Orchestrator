{
  "mcpServers": {
    "google-drive": {
      "type": "stdio",
      "command": "node",
      "args": ["/home/fields/Fields_Orchestrator/mcp-servers/gdrive/index.mjs"],
      "env": {
        "GDRIVE_OAUTH_PATH": "/home/fields/.gdrive-oauth.keys.json",
        "GDRIVE_CREDENTIALS_PATH": "/home/fields/.gdrive-server-credentials.json"
      }
    },
    "posthog": {
      "type": "http",
      "url": "https://mcp.posthog.com/mcp?readonly=true&features=flags,insights,dashboards,error_tracking,experiments",
      "headers": {
        "Authorization": "Bearer ${POSTHOG_ALL_ACCESS_KEY}"
      }
    }
  }
}
